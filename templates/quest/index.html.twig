{% extends 'base.html.twig' %}

{% block title %}Car Rental Reservation{% endblock %}

{% block body %}
<main class="bg-light min-vh-100">
    <section class="bg-white border-bottom py-5">
        <div class="container py-lg-5">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <span class="badge text-bg-primary mb-3">Fast car reservations</span>
                    <h1 class="display-4 fw-bold mb-3">Find the right car for your trip</h1>
                    <p class="lead text-secondary mb-4">
                        Choose your dates, passenger count, and let the system show the best available rental options.
                    </p>

                    <div class="d-flex flex-column flex-sm-row gap-3 mb-4">
                        <a href="{{ path('app_reservation_auto') }}" class="btn btn-primary btn-lg px-4">Reserve</a>
                        <a href="#fleet-types" class="btn btn-outline-secondary btn-lg px-4">View fleet types</a>
                    </div>

                    <div class="row g-3">
                        <div class="col-4">
                            <div class="border rounded bg-light p-3 text-center">
                                <div class="fs-4 fw-bold">1-30</div>
                                <div class="small text-secondary">Rental days</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="border rounded bg-light p-3 text-center">
                                <div class="fs-4 fw-bold">2-7</div>
                                <div class="small text-secondary">Passengers</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="border rounded bg-light p-3 text-center">
                                <div class="fs-4 fw-bold">XCG</div>
                                <div class="small text-secondary">Payments</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="bg-light border rounded-3 p-3 p-lg-4 shadow-sm">
                        <div class="ratio ratio-16x9 bg-white rounded mb-3">
                            <img
                                src="{{ asset('images/sedan_003.png') }}"
                                class="img-fluid object-fit-contain p-4"
                                alt="Sedan rental car"
                            >
                        </div>
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="ratio ratio-4x3 bg-white rounded">
                                    <img
                                        src="{{ asset('images/minivan_001.png') }}"
                                        class="img-fluid object-fit-contain p-3"
                                        alt="Minivan rental car"
                                    >
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="ratio ratio-4x3 bg-white rounded">
                                    <img
                                        src="{{ asset('images/convertible_001.png') }}"
                                        class="img-fluid object-fit-contain p-3"
                                        alt="Convertible rental car"
                                    >
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="fleet-types" class="py-5">
        <div class="container">
            <div class="row align-items-end mb-4">
                <div class="col-lg-7">
                    <span class="badge text-bg-secondary mb-3">Fleet types</span>
                    <h2 class="h1 fw-bold mb-2">Travel with the right space</h2>
                    <p class="text-secondary mb-0">
                        The reservation flow checks seats, dates, price, demand, and availability before showing options.
                    </p>
                </div>
                <div class="col-lg-5 text-lg-end mt-3 mt-lg-0">
                    <a href="{{ path('app_reservation_auto') }}" class="btn btn-primary">Reserve</a>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <article class="card h-100 border-0 shadow-sm">
                        <div class="ratio ratio-16x9 bg-body-secondary rounded-top">
                            <img
                                src="{{ asset('images/minivan_002.png') }}"
                                class="img-fluid object-fit-contain p-3"
                                alt="Minivan"
                            >
                        </div>
                        <div class="card-body">
                            <h3 class="h5">Minivans</h3>
                            <p class="text-secondary mb-0">Room for larger groups, luggage, and family trips.</p>
                        </div>
                    </article>
                </div>

                <div class="col-md-4">
                    <article class="card h-100 border-0 shadow-sm">
                        <div class="ratio ratio-16x9 bg-body-secondary rounded-top">
                            <img
                                src="{{ asset('images/sedan_001.png') }}"
                                class="img-fluid object-fit-contain p-3"
                                alt="Sedan"
                            >
                        </div>
                        <div class="card-body">
                            <h3 class="h5">Sedans</h3>
                            <p class="text-secondary mb-0">Comfortable daily rentals with efficient pricing.</p>
                        </div>
                    </article>
                </div>

                <div class="col-md-4">
                    <article class="card h-100 border-0 shadow-sm">
                        <div class="ratio ratio-16x9 bg-body-secondary rounded-top">
                            <img
                                src="{{ asset('images/convertible_002.png') }}"
                                class="img-fluid object-fit-contain p-3"
                                alt="Convertible"
                            >
                        </div>
                        <div class="card-body">
                            <h3 class="h5">Convertibles</h3>
                            <p class="text-secondary mb-0">A smaller option for weekend drives and two-person trips.</p>
                        </div>
                    </article>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-white border-top py-5">
        <div class="container">
            <div class="row g-4 align-items-center">
                <div class="col-lg-8">
                    <h2 class="h1 fw-bold mb-2">Ready to reserve?</h2>
                    <p class="text-secondary mb-0">
                        Start with your trip details and continue with the best available car.
                    </p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <a href="{{ path('app_reservation_auto') }}" class="btn btn-primary btn-lg px-5">Reserve</a>
                </div>
            </div>
        </div>
    </section>
</main>
{% endblock %}
