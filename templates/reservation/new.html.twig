{% extends 'base.html.twig' %}

{% block title %}Reserve {{ car.make }} {{ car.model }}{% endblock %}

{% block body %}
{# ai helped with the UI design #}
<main class="bg-light min-vh-100 py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="ratio ratio-16x9 bg-body-secondary rounded-top">
                        <img
                            src="{{ asset('images/' ~ car.imageFilename) }}"
                            class="img-fluid object-fit-contain p-3"
                            alt="{{ car.make }} {{ car.model }}"
                        >
                    </div>
                    <div class="card-body">
                        <span class="badge text-bg-primary mb-3">{{ car.category|title }}</span>
                        <h1 class="h4 mb-2">{{ car.make }} {{ car.model }}</h1>
                        <p class="text-secondary mb-4">{{ car.modelYear }} - {{ car.color }}</p>

                        <div class="row g-2 text-center mb-4">
                            <div class="col-4">
                                <div class="border rounded p-2 bg-light">
                                    <div class="fw-semibold">{{ car.seats }}</div>
                                    <div class="small text-secondary">Seats</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="border rounded p-2 bg-light">
                                    <div class="fw-semibold">{{ car.doors }}</div>
                                    <div class="small text-secondary">Doors</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="border rounded p-2 bg-light">
                                    <div class="fw-semibold">{{ car.luggageCapacity }}</div>
                                    <div class="small text-secondary">Bags</div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-secondary">Daily price</span>
                            <span class="fs-4 fw-bold" id="dailyPrice" data-base-price="{{ car.dailyBasePrice }}">
                                ${{ car.dailyBasePrice|number_format(2) }}
                            </span>
                        </div>
                        <div class="mt-2 text-end">
                            <span class="badge text-bg-success" id="priceIncreaseBadge">No price increase</span>
                            <small class="text-secondary d-block d-none" id="normalDailyPrice">
                                Normal daily price: ${{ car.dailyBasePrice|number_format(2) }}
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4 p-lg-5">
                        <div class="mb-4">
                            <span class="badge text-bg-success mb-3">1 to 30 days</span>
                            <h2 class="h3 mb-2">Reserve this car</h2>
                            <p class="text-secondary mb-0">
                                Enter the customer information, number of persons, and rental dates.
                            </p>
                        </div>

                        {{ form_start(reservationForm) }}
                            {{ form_errors(reservationForm) }}

                            <div class="row g-3">
                                <div class="col-md-6">
                                    {{ form_row(reservationForm.customerFirstName) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_row(reservationForm.customerLastName) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_row(reservationForm.customerEmail) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_row(reservationForm.customerPhone) }}
                                </div>
                                <div class="col-md-4">
                                    {{ form_row(reservationForm.numberOfPersons) }}
                                </div>
                                <div class="col-md-4">
                                    {{ form_row(reservationForm.startDate) }}
                                </div>
                                <div class="col-md-4">
                                    {{ form_row(reservationForm.endDate) }}
                                </div>
                            </div>

                            <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end mt-4">
                                <a href="{{ path('app_quest') }}" class="btn btn-outline-secondary">Cancel</a>
                                <button type="submit" class="btn btn-primary">Save reservation</button>
                            </div>
                        {{ form_end(reservationForm) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    const startDateInput = document.getElementById('{{ reservationForm.startDate.vars.id }}');
    const dailyPrice = document.getElementById('dailyPrice');
    const priceIncreaseBadge = document.getElementById('priceIncreaseBadge');
    const normalDailyPrice = document.getElementById('normalDailyPrice');
    const basePrice = Number(dailyPrice.dataset.basePrice);

    function updateDailyPrice() {
        const startDate = new Date(startDateInput.value);
        const month = startDate.getMonth() + 1;
        let newPrice = basePrice;
        let badgeText = 'No price increase';
        let badgeClass = 'badge text-bg-success';

        if ([6, 7, 8].includes(month)) {
            newPrice = basePrice * 1.20;
            badgeText = 'Summer +20%';
            badgeClass = 'badge text-bg-warning';
        }

        if (month === 12) {
            newPrice = basePrice * 1.15;
            badgeText = 'December +15%';
            badgeClass = 'badge text-bg-warning';
        }

        dailyPrice.textContent = '$' + newPrice.toFixed(2);
        priceIncreaseBadge.textContent = badgeText;
        priceIncreaseBadge.className = badgeClass;
        normalDailyPrice.classList.toggle('d-none', newPrice === basePrice);
    }

    startDateInput.addEventListener('change', updateDailyPrice);
    updateDailyPrice();
</script>
{% endblock %}
